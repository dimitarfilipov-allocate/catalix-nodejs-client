<% 
const user = typeof locals.user !== 'undefined' ? locals.user : null;
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Catalix App</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <i class="fas fa-rocket"></i>
                <span>Catalix</span>
            </div>
            <div class="nav-links">
                <% if (user) { %>
                    <a href="/dashboard" class="nav-link">Dashboard</a>
                    <a href="/logout" class="nav-link">Logout</a>
                <% } else { %>
                    <a href="/" class="nav-link">Home</a>
                    <a href="/login" class="nav-link">Login</a>
                    <a href="/register" class="nav-link">Register</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="hero-section">
            <div class="hero-content">
                <h1 class="hero-title">Welcome to Catalix</h1>
                <p class="hero-subtitle">Your modern Node.js application with secure authentication</p>
                <div class="hero-buttons">
                    <% if (!user) { %>
                        <a href="/login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt"></i>
                            Login
                        </a>
                        <a href="/register" class="btn btn-secondary">
                            <i class="fas fa-user-plus"></i>
                            Register
                        </a>
                    <% } else { %>
                        <a href="/dashboard" class="btn btn-primary">
                            <i class="fas fa-tachometer-alt"></i>
                            Go to Dashboard
                        </a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="features-section">
            <div class="container">
                <h2 class="section-title">Features</h2>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h3>Secure Authentication</h3>
                        <p>Built with bcrypt password hashing and secure session management</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-mobile-alt"></i>
                        </div>
                        <h3>Responsive Design</h3>
                        <p>Modern, mobile-first design that works on all devices</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <h3>Fast Performance</h3>
                        <p>Built with Express.js for high performance and scalability</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <p>&copy; 2025 Catalix App. All rights reserved.</p>
    </footer>
</body>
</html>
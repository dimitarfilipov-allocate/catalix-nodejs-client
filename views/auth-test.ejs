<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catalix Authentication Test - Catalix App</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <i class="fas fa-rocket"></i>
                <span>Catalix</span>
            </div>
            <div class="nav-links">
                <a href="/" class="nav-link">Home</a>
                <a href="/auth-test" class="nav-link active">Auth Test</a>
                <a href="/login" class="nav-link">Legacy Login</a>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            <div class="auth-test-container">
                <h1 class="section-title">
                    <i class="fas fa-passport"></i>
                    Catalix Authentication Test
                </h1>
                
                <!-- Demo Passport Generation -->
                <div class="test-section">
                    <h2>1. Generate Demo Passport</h2>
                    <p>Create a demo passport for testing purposes</p>
                    
                    <div class="form-group">
                        <label>User Data (JSON):</label>
                        <textarea id="userDataInput" rows="6" placeholder='{"UserID": "test-123", "Email": "test@catalix.com", "UserType": "demo"}'></textarea>
                    </div>
                    
                    <button onclick="generateDemoPassport()" class="btn btn-primary">
                        <i class="fas fa-plus"></i>
                        Generate Demo Passport
                    </button>
                    
                    <div id="demoResult" class="result-container"></div>
                </div>

                <!-- JWT Token to Passport -->
                <div class="test-section">
                    <h2>2. JWT Token to Passport</h2>
                    <p>Convert a JWT ID token to a Catalix passport</p>
                    
                    <div class="form-group">
                        <label>JWT ID Token:</label>
                        <textarea id="jwtTokenInput" rows="4" placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."></textarea>
                    </div>
                    
                    <button onclick="generatePassportFromToken()" class="btn btn-primary">
                        <i class="fas fa-exchange-alt"></i>
                        Convert to Passport
                    </button>
                    
                    <div id="jwtResult" class="result-container"></div>
                </div>

                <!-- Passport Validation -->
                <div class="test-section">
                    <h2>3. Validate Passport</h2>
                    <p>Test passport validation and decode user information</p>
                    
                    <div class="form-group">
                        <label>Passport String:</label>
                        <textarea id="passportInput" rows="3" placeholder="v1.eyJ..."></textarea>
                    </div>
                    
                    <button onclick="validatePassport()" class="btn btn-secondary">
                        <i class="fas fa-check"></i>
                        Validate Passport
                    </button>
                    
                    <div id="validateResult" class="result-container"></div>
                </div>

                <!-- API Testing -->
                <div class="test-section">
                    <h2>4. Test Protected Endpoints</h2>
                    <p>Test API calls with passport authentication</p>
                    
                    <div class="api-buttons">
                        <button onclick="testDashboard()" class="btn btn-outline">
                            <i class="fas fa-tachometer-alt"></i>
                            Test Dashboard
                        </button>
                        
                        <button onclick="testUsersAPI()" class="btn btn-outline">
                            <i class="fas fa-users"></i>
                            Test Users API
                        </button>
                        
                        <button onclick="testAdminAPI()" class="btn btn-outline">
                            <i class="fas fa-shield-alt"></i>
                            Test Admin API
                        </button>
                    </div>
                    
                    <div id="apiResult" class="result-container"></div>
                </div>

                <!-- Current Passport Display -->
                <div class="test-section">
                    <h2>5. Current Session</h2>
                    <p>Currently stored passport information</p>
                    
                    <button onclick="showCurrentPassport()" class="btn btn-secondary">
                        <i class="fas fa-info-circle"></i>
                        Show Current Passport
                    </button>
                    
                    <button onclick="clearPassport()" class="btn btn-outline">
                        <i class="fas fa-trash"></i>
                        Clear Passport
                    </button>
                    
                    <div id="currentResult" class="result-container"></div>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <p>&copy; 2025 Catalix App - Authentication Testing Interface</p>
    </footer>

    <script>
        // Store current passport for testing
        let currentPassport = localStorage.getItem('catalix-passport') || '';

        // Generate demo passport
        async function generateDemoPassport() {
            try {
                const userDataText = document.getElementById('userDataInput').value;
                let userData = {};
                
                if (userDataText.trim()) {
                    userData = JSON.parse(userDataText);
                }

                const response = await fetch('/demo-passport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userData })
                });

                const result = await response.json();
                
                if (result.success) {
                    currentPassport = result.passport;
                    localStorage.setItem('catalix-passport', currentPassport);
                    
                    document.getElementById('demoResult').innerHTML = `
                        <div class="alert alert-success">
                            <h4>✅ Demo Passport Generated</h4>
                            <p><strong>Passport:</strong> <code>${result.passport}</code></p>
                            <small>Passport saved to localStorage for testing</small>
                        </div>
                    `;
                } else {
                    throw new Error(result.message || 'Failed to generate passport');
                }
            } catch (error) {
                document.getElementById('demoResult').innerHTML = `
                    <div class="alert alert-error">
                        <h4>❌ Error</h4>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        // Generate passport from JWT token
        async function generatePassportFromToken() {
            try {
                const token = document.getElementById('jwtTokenInput').value.trim();
                
                if (!token) {
                    throw new Error('JWT token is required');
                }

                const response = await fetch('/start-session', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token })
                });

                const result = await response.json();
                
                if (result.success) {
                    currentPassport = result.passport;
                    localStorage.setItem('catalix-passport', currentPassport);
                    
                    document.getElementById('jwtResult').innerHTML = `
                        <div class="alert alert-success">
                            <h4>✅ Passport Generated from JWT</h4>
                            <p><strong>Passport:</strong> <code>${result.passport}</code></p>
                            <small>Passport saved to localStorage for testing</small>
                        </div>
                    `;
                } else {
                    throw new Error(result.message || 'Failed to generate passport');
                }
            } catch (error) {
                document.getElementById('jwtResult').innerHTML = `
                    <div class="alert alert-error">
                        <h4>❌ Error</h4>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        // Validate passport
        async function validatePassport() {
            try {
                const passportText = document.getElementById('passportInput').value.trim() || currentPassport;
                
                if (!passportText) {
                    throw new Error('Passport is required');
                }

                const response = await fetch('/validate-passport', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ passport: passportText })
                });

                const result = await response.json();
                
                if (result.valid) {
                    document.getElementById('validateResult').innerHTML = `
                        <div class="alert alert-success">
                            <h4>✅ Passport Valid</h4>
                            <div class="user-info">
                                <p><strong>User ID:</strong> ${result.user.id}</p>
                                <p><strong>Email:</strong> ${result.user.email}</p>
                                <p><strong>User Type:</strong> ${result.user.userType}</p>
                                <p><strong>Groups:</strong> ${result.user.userGroups.join(', ')}</p>
                                <p><strong>Support User:</strong> ${result.user.isSupportUser ? 'Yes' : 'No'}</p>
                            </div>
                        </div>
                    `;
                } else {
                    document.getElementById('validateResult').innerHTML = `
                        <div class="alert alert-error">
                            <h4>❌ Invalid Passport</h4>
                            <p>${result.error}</p>
                        </div>
                    `;
                }
            } catch (error) {
                document.getElementById('validateResult').innerHTML = `
                    <div class="alert alert-error">
                        <h4>❌ Error</h4>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        // Test protected endpoints
        async function testEndpoint(url, description) {
            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 
                        'x-passport': currentPassport,
                        'Accept': 'application/json'
                    }
                });

                const result = response.ok ? await response.json() : { error: await response.text() };
                
                return {
                    success: response.ok,
                    status: response.status,
                    result: result
                };
            } catch (error) {
                return {
                    success: false,
                    status: 0,
                    result: { error: error.message }
                };
            }
        }

        async function testDashboard() {
            const result = await testEndpoint('/dashboard', 'Dashboard');
            displayAPIResult('Dashboard Test', result);
        }

        async function testUsersAPI() {
            const result = await testEndpoint('/api/users', 'Users API');
            displayAPIResult('Users API Test', result);
        }

        async function testAdminAPI() {
            const result = await testEndpoint('/admin', 'Admin API');
            displayAPIResult('Admin API Test', result);
        }

        function displayAPIResult(testName, result) {
            const alertClass = result.success ? 'alert-success' : 'alert-error';
            const icon = result.success ? '✅' : '❌';
            
            document.getElementById('apiResult').innerHTML = `
                <div class="alert ${alertClass}">
                    <h4>${icon} ${testName} (${result.status})</h4>
                    <pre>${JSON.stringify(result.result, null, 2)}</pre>
                </div>
            `;
        }

        function showCurrentPassport() {
            if (currentPassport) {
                document.getElementById('currentResult').innerHTML = `
                    <div class="alert alert-success">
                        <h4>📋 Current Passport</h4>
                        <p><code>${currentPassport}</code></p>
                        <small>Stored in localStorage</small>
                    </div>
                `;
            } else {
                document.getElementById('currentResult').innerHTML = `
                    <div class="alert alert-error">
                        <h4>❌ No Passport</h4>
                        <p>No passport currently stored</p>
                    </div>
                `;
            }
        }

        function clearPassport() {
            currentPassport = '';
            localStorage.removeItem('catalix-passport');
            document.getElementById('currentResult').innerHTML = `
                <div class="alert alert-success">
                    <h4>🗑️ Passport Cleared</h4>
                    <p>Passport removed from localStorage</p>
                </div>
            `;
        }

        // Load stored passport on page load
        window.onload = function() {
            if (currentPassport) {
                showCurrentPassport();
            }
        };
    </script>

    <style>
        .auth-test-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 2rem;
        }

        .test-section {
            background: white;
            padding: 2rem;
            margin-bottom: 2rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .test-section h2 {
            color: #333;
            margin-bottom: 0.5rem;
        }

        .test-section p {
            color: #666;
            margin-bottom: 1.5rem;
        }

        .form-group textarea {
            width: 100%;
            padding: 0.75rem;
            border: 2px solid #e9ecef;
            border-radius: 6px;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
            resize: vertical;
        }

        .result-container {
            margin-top: 1rem;
        }

        .user-info {
            background: #f8f9fa;
            padding: 1rem;
            border-radius: 6px;
            margin-top: 0.5rem;
        }

        .api-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

        pre {
            background: #f8f9fa;
            padding: 1rem;
            border-radius: 6px;
            overflow-x: auto;
            font-size: 0.85rem;
        }

        @media (max-width: 768px) {
            .api-buttons {
                flex-direction: column;
            }
            
            .api-buttons .btn {
                width: 100%;
            }
        }
    </style>
</body>
</html>